# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Embedding method: "openrouter" or "local"
EMBEDDING_METHOD=openrouter

# LLM method: "openrouter" or "local"
LLM_METHOD=openrouter

# OpenRouter model for embeddings (if EMBEDDING_METHOD=openrouter)
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large

# OpenRouter model for LLM (if LLM_METHOD=openrouter)
OPENROUTER_LLM_MODEL=stepfun/step-3.5-flash:free

# Local LLM settings (if LLM_METHOD=local)
LOCAL_LLM_URL=http://localhost:8000/v1
LOCAL_LLM_MODEL=qwen3.5-9b

# Local embedding model name (if EMBEDDING_METHOD=local)
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunk size for document splitting
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Maximum context length in tokens
MAX_CONTEXT_TOKENS=8000
